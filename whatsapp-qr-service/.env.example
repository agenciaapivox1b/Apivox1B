# ============================================
# CONFIGURAÇÃO DO SERVIÇO WHATSAPP QR
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Security
API_KEY=sua-chave-secreta-aqui-mude-em-producao
JWT_SECRET=outra-chave-secreta-para-jwt

# Supabase Configuration
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_KEY=sua-service-role-key

# Redis Configuration (para persistência de sessão)
# Use Redis local ou Redis Cloud (Railway/Upstash)
REDIS_URL=redis://localhost:6379
# Ou para Redis Cloud:
# REDIS_URL=rediss://default:sua-senha@seu-redis.upstash.io:6379

# Baileys Configuration
SESSION_TTL=86400
QR_TIMEOUT=60000
RECONNECT_INTERVAL=5000

# Logging
LOG_LEVEL=info
# Opções: trace, debug, info, warn, error, fatal

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_PING_TIMEOUT=10000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha todas as variáveis
# 3. NUNCA commite o arquivo .env
# ============================================
